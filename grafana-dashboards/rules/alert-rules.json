{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "Backend error",
      "folder": "Backend Alerts",
      "interval": "10s",
      "rules": [
        {
          "uid": "dff45i5i7pzpcd",
          "title": "Backend health check",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "relativeTimeRange": {
                "from": 600,
                "to": 0
              },
              "datasourceUid": "fff3rff6r591cf",
              "model": {
                "editorMode": "code",
                "expr": "up{job=\"spring-backend\"}",
                "instant": true,
                "intervalMs": 1000,
                "legendFormat": "__auto",
                "maxDataPoints": 43200,
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "C",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": {
                      "params": [
                        1
                      ],
                      "type": "lt"
                    },
                    "operator": {
                      "type": "and"
                    },
                    "query": {
                      "params": []
                    },
                    "reducer": {
                      "params": [],
                      "type": "last"
                    },
                    "type": "query"
                  }
                ],
                "datasource": {
                  "type": "__expr__",
                  "uid": "__expr__"
                },
                "expression": "B",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "threshold"
              }
            },
            {
              "refId": "B",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": {
                      "params": [
                        0,
                        0
                      ],
                      "type": "gt"
                    },
                    "operator": {
                      "type": "and"
                    },
                    "query": {
                      "params": []
                    },
                    "reducer": {
                      "params": [],
                      "type": "avg"
                    },
                    "type": "query"
                  }
                ],
                "datasource": {
                  "name": "Expression",
                  "type": "__expr__",
                  "uid": "__expr__"
                },
                "expression": "A",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "reducer": "last",
                "refId": "B",
                "type": "reduce"
              }
            }
          ],
          "noDataState": "Alerting",
          "execErrState": "Alerting",
          "for": "1m",
          "annotations": {
            "description": "Kérem az üzemeltetőket hogy vizsgálják meg a problémát!",
            "summary": "Leállt a backend szolgáltatás"
          },
          "labels": {
            "service": "usermaintenance"
          },
          "isPaused": false,
          "notification_settings": {
            "receiver": "Usermaintenance Backend errors Discord"
          }
        }
      ]
    },
    {
      "orgId": 1,
      "name": "HTTP-Errors",
      "folder": "Backend Alerts",
      "interval": "30s",
      "rules": [
        {
          "uid": "aff44b8xx05c0a",
          "title": "HTTP 5xx Errors - Usermaintenance",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "relativeTimeRange": {
                "from": 600,
                "to": 0
              },
              "datasourceUid": "fff3rff6r591cf",
              "model": {
                "editorMode": "code",
                "expr": "sum(increase(http_server_requests_seconds_count{application=\"usermaintenance\", status=~\"5..\"}[1m]))",
                "instant": true,
                "intervalMs": 1000,
                "legendFormat": "__auto",
                "maxDataPoints": 43200,
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "C",
              "relativeTimeRange": {
                "from": 0,
                "to": 0
              },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": {
                      "params": [
                        0
                      ],
                      "type": "gt"
                    },
                    "operator": {
                      "type": "and"
                    },
                    "query": {
                      "params": []
                    },
                    "reducer": {
                      "params": [],
                      "type": "last"
                    },
                    "type": "query"
                  }
                ],
                "datasource": {
                  "type": "__expr__",
                  "uid": "__expr__"
                },
                "expression": "A",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "threshold"
              }
            }
          ],
          "noDataState": "Alerting",
          "execErrState": "Alerting",
          "for": "30s",
          "annotations": {
            "description": "Az utolsó fél percben 500-as típusú válasz érkezett az API-tól. Ellenőrizd a logokat!",
            "summary": "5xx hiba történt az usermaintenance backendben!"
          },
          "labels": {
            "service": "usermaintenance",
            "severity": "critical"
          },
          "isPaused": false,
          "notification_settings": {
            "receiver": "Usermaintenance Backend errors Discord"
          }
        }
      ]
    }
  ]
}